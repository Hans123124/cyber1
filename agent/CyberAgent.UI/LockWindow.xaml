<Window x:Class="CyberAgent.UI.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberClub – Locked"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#1a1a2e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Lock icon / branding -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="🔒"
                       FontSize="96"
                       HorizontalAlignment="Center"
                       Foreground="White"
                       Margin="0,0,0,20"/>

            <TextBlock x:Name="TitleText"
                       Text="Station Locked"
                       FontSize="40"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="SubtitleText"
                       Text="Please contact the administrator to start a session."
                       FontSize="18"
                       Foreground="#aaaacc"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <TextBlock x:Name="WorkstationLabel"
                       Text=""
                       FontSize="14"
                       Foreground="#666688"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="ClockText"
                       FontSize="28"
                       Foreground="#888899"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <TextBlock x:Name="CountdownText"
                       FontSize="22"
                       Foreground="#00cc88"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"
                       Visibility="Collapsed"/>

            <Button x:Name="CallAdminButton"
                    Content="📞  Call Admin"
                    FontSize="16"
                    Padding="24,10"
                    Background="#16213e"
                    Foreground="White"
                    BorderBrush="#0f3460"
                    BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    Click="CallAdmin_Click"/>
        </StackPanel>

        <!-- Status bar -->
        <TextBlock x:Name="StatusBar"
                   Grid.Row="2"
                   Text="Connecting..."
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   FontSize="12"
                   Foreground="#444466"/>
    </Grid>
</Window>
